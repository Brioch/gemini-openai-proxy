# Gemini OpenAI Proxy Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=11434

# Authentication Configuration
# Options: oauth-personal, gemini-api-key, vertex-ai
AUTH_TYPE=gemini-api-key

# API Key (required when AUTH_TYPE=gemini-api-key)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Configuration (required when AUTH_TYPE=oauth-personal or vertex-ai)
# Your Google Cloud Project ID
# GOOGLE_CLOUD_PROJECT=your_project_id_here

# Path to Google Application Credentials JSON file (required for oauth-personal)
# For local development: path to OAuth credentials file (usually ~/.gemini/oauth_creds.json)
# For Docker: use /app/credentials.json and mount the file with -v flag
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/credentials.json

# Your Google Cloud Location (e.g., us-central1)
# GOOGLE_CLOUD_LOCATION=us-central1

# Enable Vertex AI usage
# GOOGLE_GENAI_USE_VERTEXAI=true

# Authentication Type Examples:
#
# 1. For API Key authentication (simplest):
#    AUTH_TYPE=gemini-api-key
#    GEMINI_API_KEY=your_api_key_from_google_ai_studio
#
# 2. For OAuth Personal (free access):
#    AUTH_TYPE=oauth-personal
#    GOOGLE_CLOUD_PROJECT=your_project_id
#    GOOGLE_APPLICATION_CREDENTIALS=/Users/username/.gemini/oauth_creds.json
#
# 3. For Vertex AI:
#    AUTH_TYPE=vertex-ai
#    GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID
#    GOOGLE_CLOUD_LOCATION=us-central1
#    GOOGLE_GENAI_USE_VERTEXAI=true
